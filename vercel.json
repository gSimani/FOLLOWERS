{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "hello-world-webpage/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/hello-world-webpage/index.html"
    }
  ],
  "github": {
    "enabled": true,
    "silent": true,
    "autoAlias": true,
    "autoJobCancelation": true
  }
}
